<!-- Scope Card Check -->
<div class="dashboard-card">
    <h3>🏫 Assigned Institutional Scope</h3>
    <% if (typeof center !== 'undefined' && center) { %>
        <p><strong>Center Name:</strong> <%= center.name_of_center || 'Un-named' %> | <strong>DDO Identity Code:</strong> <code><%= center.ddo_code || 'N/A' %></code> | <strong>Status:</strong> <%= center.status || 'Active' %></p>
    <% } else { %>
        <p style="color: red;">Error: Profile mapping parameters missing from system registry.</p>
    <% } %>
</div>

<!-- Incoming Docs Table Body Check -->
<tbody>
    <% if (typeof incomingDocs !== 'undefined' && Array.isArray(incomingDocs) && incomingDocs.length > 0) { %>
        <% incomingDocs.forEach(function(doc) { %>
            <tr><td><%= doc.title %></td><td><a href="<%= doc.file_url %>" class="action-btn" target="_blank">Review Asset</a></td></tr>
        <% }); %>
    <% } else { %> <tr><td colspan="2">No directives dispatched from Directorate General.</td></tr> <% } %>
</tbody>

<!-- Outgoing Docs Table Body Check -->
<tbody>
    <% if (typeof outgoingDocs !== 'undefined' && Array.isArray(outgoingDocs) && outgoingDocs.length > 0) { %>
        <% outgoingDocs.forEach(function(doc) { %>
            <tr><td><a href="<%= doc.file_url %>" target="_blank"><%= doc.title %></a></td><td><%= new Date(doc.uploaded_at).toLocaleDateString() %></td></tr>
        <% }); %>
    <% } else { %> <tr><td colspan="2">No documents transmitted upwards yet.</td></tr> <% } %>
</tbody>

<!-- Trainees Table Body Check -->
<tbody>
    <% if (typeof trainees !== 'undefined' && Array.isArray(trainees) && trainees.length > 0) { %>
        <% trainees.forEach(function(student) { %>
            <tr>
                <td><code><%= student.trainee_id %></code></td>
                <td><strong><%= student.full_name %></strong></td>
                <td><%= student.cnic %></td>
                <td><%= student.district || 'Unmapped' %></td>
                <td><small>Bank: <%= student.bank_account_number || 'N/A' %><br>EasyPaisa: <%= student.easypaisa_number || 'N/A' %></small></td>
                <td>
                    <form action="/ddo/update-trainee-status" method="POST">
                        <input type="hidden" name="id" value="<%= student.id %>">
                        <select name="status" onchange="this.form.submit()">
                            <option value="Pending" <%= student.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                            <option value="Approved" <%= student.status === 'Approved' ? 'selected' : '' %>>Approve</option>
                            <option value="Rejected" <%= student.status === 'Rejected' ? 'selected' : '' %>>Reject</option>
                        </select>
                    </form>
                </td>
            </tr>
        <% }); %>
    <% } else { %> <tr><td colspan="6" style="text-align: center;">No earmarked trainees allocated to this center unit.</td></tr> <% } %>
</tbody>
