<tbody>
  <% if (typeof centers !== 'undefined' && Array.isArray(centers) && centers.length > 0) { %>
    <% centers.forEach(function(center) { %>
      <tr>
        <td><%= center.s_no || '-' %></td>
        <td><code><%= center.ddo_code || '-' %></code></td>
        <td><strong><%= center.name_of_center || 'Un-named Center' %></strong></td>
        <td><span class="badge <%= center.status || 'Functional' %>"><%= center.status || 'Functional' %></span></td>
        <td><span class="badge <%= center.type || 'Govt' %>"><%= center.type || 'Govt' %></span></td>
        <td><%= center.ddo_name || 'Unassigned' %></td>
        <% if (center.dynamic_columns && typeof center.dynamic_columns === 'object') { %>
          <% Object.keys(center.dynamic_columns).forEach(function(key) { %>
            <td><%= center.dynamic_columns[key] || '-' %></td>
          <% }); %>
        <% } %>
      </tr>
    <% }); %>
  <% } else { %>
    <tr><td colspan="10" style="text-align:center; padding:20px; color:#666;">No active training centers found in repository schema.</td></tr>
  <% } %>
</tbody>
