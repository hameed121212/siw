<label for="center_id">Target Assignment Training Center</label>
<select id="center_id" name="center_id" style="width:100%; padding:10px; border:1px solid #ccc; border-radius:4px;" required>
  <option value="">-- Choose Center Selection --</option>
  <% if (typeof centers !== 'undefined' && Array.isArray(centers) && centers.length > 0) { %>
    <% centers.forEach(function(center) { %>
      <% if (center && center.id && center.name_of_center) { %>
        <option value="<%= center.id %>"><%= center.name_of_center %></option>
      <% } %>
    <% }); %>
  <% } else { %>
    <option value="">No Active Training Centers Available</option>
  <% } %>
</select>
