<%- include('layout', { body: `
<main class="main-layout">
  <!-- Trainee Registration Component -->
  <div class="card">
    <h2>Trainee Registration Desk</h2>
    <p>Fill out the application parameters below to request admission verification.</p>
    <hr>
    <form action="/submit-trainee" method="POST">
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" name="full_name" placeholder="Enter Full Name" required>
      </div>
      <div class="form-group">
        <label>CNIC Number</label>
        <input type="text" name="cnic" placeholder="Format: 54400-0000000-0" required>
      </div>
      <div class="form-group">
        <label>Mobile Contact Number</label>
        <input type="text" name="mobile_number" placeholder="Enter Mobile Number" required>
      </div>
      <div class="form-group">
        <label>Target Assignment Training Center</label>
        <select name="center_id" required>
          <option value="">-- Choose Center Selection --</option>
          ${centers.map(c => `<option value="${c.id}">${c.name_of_center} (${c.ddo_code})</option>`).join('')}
        </select>
      </div>
      <div class="form-group">
        <label>Course Name</label>
        <input type="text" name="course_name" placeholder="e.g., Computer Applications, Tailoring" required>
      </div>

      <h3 style="margin-top: 25px; border-bottom: 1px solid #ddd; padding-bottom: 5px;">🌍 Geographical Information</h3>
      <div class="form-group">
        <label>District</label>
        <input type="text" name="district" placeholder="e.g., Quetta, Mastung, Gwadar" required>
      </div>
      <div class="form-group">
        <label>Tehsil</label>
        <input type="text" name="tehsil" placeholder="Enter Tehsil" required>
      </div>
      <div class="form-group">
        <label>Union Council (UC)</label>
        <input type="text" name="union_council" placeholder="Enter Union Council Name">
      </div>

      <h3 style="margin-top: 25px; border-bottom: 1px solid #ddd; padding-bottom: 5px;">💰 Financial Information</h3>
      <div class="form-group">
        <label>Vendor Number (Optional)</label>
        <input type="text" name="vendor_number" placeholder="Enter Government Vendor Code">
      </div>
      <div class="form-group">
        <label>Bank Account Number (IBAN)</label>
        <input type="text" name="bank_account_number" placeholder="PK00 BANK 0000 0000 0000">
      </div>
      <div class="form-group">
        <label>EasyPaisa Number</label>
        <input type="text" name="easypaisa_number" placeholder="e.g., 03XXXXXXXXX">
      </div>

      <button type="submit" style="margin-top:15px;">Submit Enrolment File Form</button>
    </form>
  </div>

  <!-- Secure Login Terminal Access -->
  <div class="card" style="height: fit-content;">
    <h2>Secure Management Terminal Access</h2>
    <p>Internal portal administration authorization screen.</p>
    <hr>
    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label>Username / Account ID Token</label>
        <input type="text" name="username" placeholder="Username" required>
      </div>
      <div class="form-group">
        <label>Security Password String</label>
        <input type="password" name="password" placeholder="Password" required>
      </div>
      <button type="submit" style="background-color: #b7094c;">Authenticate Portal Link</button>
    </form>
  </div>
</main>
` }) %>
