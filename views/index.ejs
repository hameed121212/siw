<div class="grid">
    <div class="card">
        <h2>Trainee Registration Desk</h2>
        <% if (successId) { %>
            <div class="alert">
                Registration Complete! Your Permanent Enrolled ID is: <%= successId %>
            </div>
        <% } %>
        <form action="/apply" method="POST">
            <label>Full Name</label>
            <input type="text" name="full_name" placeholder="Enter Full Name" required>
            
            <label>CNIC Number</label>
            <input type="text" name="cnic" placeholder="Format: 54400-0000000-0" required>
            
            <label>Mobile Contact Number</label>
            <input type="text" name="phone" placeholder="Enter Mobile Number" required>
            
            <label>Target Assignment Training Center</label>
            <select name="ddo_code" required>
                <option value="">-- Choose Center Selection --</option>
                <% centers.forEach(center => { %>
                    <option value="<%= center.ddo_code %>"><%= center.center_name %> (<%= center.ddo_code %>)</option>
                <% }) %>
            </select>
            <button type="submit">Submit Enrolment File Form</button>
        </form>
    </div>

    <div class="card">
        <h2>Secure Management Terminal Access</h2>
        <form action="/login" method="POST">
            <label>Username / Account ID Token</label>
            <input type="text" name="username" placeholder="Username" required>
            
            <label>Security Password String</label>
            <input type="password" name="password" placeholder="Password" required>
            
            <button type="submit" style="background-color: #c29b38;">Authenticate Portal Link</button>
        </form>
    </div>
</div>
